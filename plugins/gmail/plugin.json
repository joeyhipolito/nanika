{
  "name": "gmail",
  "version": "0.3.0",
  "api_version": 1,
  "description": "Gmail CLI — read inbox, triage threads, apply labels, manage filters, send and reply to email across multiple Gmail accounts. Supports query status/items/actions for unread counts and quick status.",
  "icon": "LetterOpened",
  "binary": "gmail",
  "build": "go build -ldflags \"-s -w\" -o bin/gmail ./cmd/gmail-cli",
  "install": "ln -sf $(pwd)/bin/gmail ~/bin/gmail",
  "ui": true,
  "tags": ["gmail", "email", "inbox", "productivity", "google"],
  "repository": {
    "type": "git",
    "url": "https://github.com/joeyhipolito/nanika",
    "path": "plugins/gmail"
  },
  "actions": {
    "query status": {
      "command": "gmail query status --json",
      "description": "Account status: unread count per account and total unread",
      "output": "status"
    },
    "query items": {
      "command": "gmail query items --json",
      "description": "Unread inbox threads across all accounts",
      "output": "items"
    },
    "query actions": {
      "command": "gmail query actions --json",
      "description": "Available CLI actions with commands and descriptions",
      "output": "actions"
    }
  },
  "capabilities": {
    "description": "Read, search, label, and send email across multiple Gmail accounts. Also accesses Google Calendar and Drive. Use when the user asks about email, inbox, unread messages, sending mail, calendar events, or Google Drive files.",
    "triggers": [
      "check my email",
      "any unread messages",
      "send an email to someone",
      "find emails from John",
      "label that thread",
      "what's on my calendar",
      "reply to that email"
    ],
    "entities": {
      "thread": {
        "pattern": "[0-9a-f]{8,}",
        "mentionable": true,
        "description": "Gmail thread ID"
      },
      "account": {
        "pattern": "<alias> (e.g., work, personal)",
        "mentionable": true,
        "description": "Configured Gmail account alias"
      },
      "draft": {
        "pattern": "r<digits>",
        "mentionable": false,
        "description": "Gmail draft ID"
      }
    },
    "commands": {
      "inbox": {
        "description": "List inbox threads",
        "args": ["--unread", "--account <alias>", "--limit <n>"]
      },
      "thread": {
        "description": "Read a specific email thread",
        "args": ["<thread-id>", "--account <alias>"]
      },
      "search": {
        "description": "Search emails with Gmail query syntax",
        "args": ["<query>", "--account <alias>", "--limit <n>"]
      },
      "send": {
        "description": "Send a new email",
        "args": ["--to <email>", "--subject <text>", "<body>", "--cc <email>", "--account <alias>"]
      },
      "reply": {
        "description": "Reply to an email thread",
        "args": ["<thread-id>", "<body>", "--account <alias>"]
      },
      "label": {
        "description": "Apply or remove a label from a thread",
        "args": ["<thread-id>", "<label-name>", "--remove <label>", "--account <alias>"]
      },
      "mark": {
        "description": "Mark a thread as read, unread, archived, or trashed",
        "args": ["<thread-id>", "--read|--unread|--archive|--trash", "--account <alias>"]
      },
      "draft create": {
        "description": "Create a draft email",
        "args": ["--to <email>", "--subject <text>", "<body>", "--account <alias>"]
      },
      "draft list": {
        "description": "List saved drafts",
        "args": ["--account <alias>"]
      },
      "draft send": {
        "description": "Send a saved draft",
        "args": ["<draft-id>", "--account <alias>"]
      },
      "calendar list": {
        "description": "List upcoming calendar events",
        "args": ["--limit <n>", "--account <alias>"]
      },
      "calendar create": {
        "description": "Create a calendar event",
        "args": ["--summary <text>", "--start <datetime>", "--end <datetime>", "--attendee <email>", "--account <alias>"]
      },
      "drive list": {
        "description": "List recent Google Drive files",
        "args": ["--limit <n>", "--account <alias>"]
      },
      "drive search": {
        "description": "Search Google Drive files by name or content",
        "args": ["<query>", "--limit <n>", "--account <alias>"]
      }
    }
  }
}
