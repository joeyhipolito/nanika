{
  "$schema": "../plugin.schema.json",
  "name": "engage",
  "version": "0.1.0",
  "api_version": 1,
  "description": "Cross-platform engagement enrichment — scan opportunities and enrich with full context across YouTube, LinkedIn, Reddit, Substack, and X.",
  "icon": "Like",
  "binary": "engage",
  "build": "go build -ldflags \"-s -w\" -o bin/engage ./cmd/engage-cli",
  "install": "ln -sf $(pwd)/bin/engage ~/.alluka/bin/engage",
  "tags": ["engagement", "enrichment", "youtube", "linkedin", "reddit", "substack", "x"],
  "repository": {
    "type": "git",
    "url": "https://github.com/joeyhipolito/nanika",
    "path": "plugins/engage"
  },
  "ui": true,
  "ui_metadata": {
    "sidebar_label": "Engage",
    "sidebar_description": "Queue management and comment drafts across platforms",
    "icon_override": "Like"
  },
  "provides": ["drafts", "queue"],
  "actions": {
    "query status": {
      "command": "engage query status --json",
      "description": "Planner snapshot with queue counts, platform rollups, and real posting history",
      "output": "status"
    },
    "query items": {
      "command": "engage query items --json",
      "description": "List full queue drafts with opportunity context, comment body, review metadata, and summary fields",
      "output": "items"
    },
    "query action approve": {
      "command": "engage query action approve <id> --json",
      "description": "Approve a pending draft",
      "output": "action"
    },
    "query action reject": {
      "command": "engage query action reject <id> --json",
      "description": "Reject a pending draft",
      "output": "action"
    }
  }
}
