{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "dashboard: preview",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/plugins/dashboard",
      "preLaunchTask": "start-dashboard"
    },
    {
      "name": "dashboard: channel server (standalone)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "${workspaceFolder}/plugins/dashboard/channel/index.ts"],
      "env": {
        "DASHBOARD_CHANNEL_PORT": "7332"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
